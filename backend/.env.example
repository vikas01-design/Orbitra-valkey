# Copy this file to .env and fill in your values

# Server
PORT=5000

# Valkey / Redis connection
# Local Docker:
VALKEY_HOST=127.0.0.1
VALKEY_PORT=6379
VALKEY_PASSWORD=

# AWS ElastiCache (uncomment and fill when deploying to AWS):
# VALKEY_HOST=your-cluster.abc123.ng.0001.use1.cache.amazonaws.com
# VALKEY_PORT=6379
# VALKEY_PASSWORD=your-auth-token

# Frontend origin for CORS
FRONTEND_URL=http://localhost:3000
